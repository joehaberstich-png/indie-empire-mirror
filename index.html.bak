/* FLOATING BUBBLE */
.floating-bubble{position:fixed;bottom:28px;right:28px;z-index:10000;display:flex;flex-direction:column;align-items:flex-end;gap:8px}
.bubble-toggle{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#00d4ff,#22c55e);border:none;cursor:pointer;box-shadow:0 4px 24px rgba(0,212,255,.3);transition:all .3s;display:flex;align-items:center;justify-content:center;font-size:28px;color:#fff;position:relative}
.bubble-toggle:hover{transform:scale(1.08);box-shadow:0 6px 32px rgba(0,212,255,.4)}
.bubble-toggle .pulse-ring{position:absolute;inset:-4px;border-radius:50%;border:2px solid rgba(0,212,255,.15);animation:pulse-ring 2s infinite}
@keyframes pulse-ring{0%{transform:scale(1);opacity:1}100%{transform:scale(1.3);opacity:0}}
.bubble-toggle.open{transform:rotate(45deg)}
.chat-window{display:none;width:360px;max-height:520px;background:#0a0a12;border:1px solid rgba(0,212,255,.12);border-radius:16px;overflow:hidden;box-shadow:0 8px 48px rgba(0,0,0,.5);flex-direction:column;animation:slide-up .3s ease}
.chat-window.open{display:flex}
@keyframes slide-up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.chat-header{padding:14px 16px;background:linear-gradient(135deg,rgba(0,212,255,.08),rgba(34,197,94,.08));border-bottom:1px solid rgba(0,212,255,.08);display:flex;align-items:center;gap:10px}
.chat-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#00d4ff,#22c55e);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#050508}
.chat-header-info{flex:1}
.chat-header-info .name{font-size:12px;font-weight:700;color:#fff}
.chat-header-info .status{font-size:9px;color:#22c55e;display:flex;align-items:center;gap:4px}
.chat-header-info .status .dot{width:5px;height:5px;border-radius:50%;background:#22c55e}
.chat-messages{flex:1;padding:12px;overflow-y:auto;max-height:340px;min-height:200px;display:flex;flex-direction:column;gap:8px}
.chat-msg{max-width:85%;padding:10px 14px;border-radius:12px;font-size:11px;line-height:1.5;word-wrap:break-word}
.chat-msg.bot{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.08);color:#ccc;align-self:flex-start;border-bottom-left-radius:4px}
.chat-msg.user{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.1);color:#ddd;align-self:flex-end;border-bottom-right-radius:4px}
.chat-msg .time{font-size:8px;color:#444;margin-top:4px;display:block}
.chat-input{border-top:1px solid rgba(0,212,255,.06);padding:10px 12px;display:flex;gap:8px}
.chat-input input{flex:1;background:#050508;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:11px;outline:none}
.chat-input input:focus{border-color:var(--cyan, #00d4ff)}
.chat-input button{padding:10px 16px;background:linear-gradient(135deg,#00d4ff,#22c55e);border:none;border-radius:8px;color:#050508;font-weight:700;font-size:10px;cursor:pointer;transition:all .2s}
.chat-input button:hover{transform:translateY(-1px);box-shadow:0 2px 12px rgba(0,212,255,.2)}
.chat-quick{display:flex;gap:4px;padding:6px 12px;flex-wrap:wrap;border-top:1px solid rgba(0,212,255,.04)}
.chat-quick button{font-size:8px;padding:4px 8px;border-radius:100px;border:1px solid #1a1a1f;background:transparent;color:#555;cursor:pointer;transition:all .2s}
.chat-quick button:hover{border-color:var(--cyan,#00d4ff);color:var(--cyan)}
</style>
</head>
<body>

<!-- FLOATING BUBBLE -->
<div class="floating-bubble" id="saulBubble">
  <div class="chat-window" id="chatWindow">
    <div class="chat-header">
      <div class="chat-avatar">S</div>
      <div class="chat-header-info">
        <div class="name">Saul · Mirror AI</div>
        <div class="status"><span class="dot"></span> Online · Ready to assist</div>
      </div>
    </div>
    <div class="chat-messages" id="chatMessages"></div>
    <div class="chat-quick">
      <button onclick="sendQuick('Show projects')">📋 Projects</button>
      <button onclick="sendQuick('Show rules')">📜 Rules</button>
      <button onclick="sendQuick('Run tests')">🧪 Tests</button>
      <button onclick="sendQuick('Backup portal')">🔐 Portal</button>
    </div>
    <div class="chat-input">
      <input type="text" id="chatInput" placeholder="Ask me anything..." onkeydown="if(event.key==='Enter')sendMessage()">
      <button onclick="sendMessage()">Send</button>
    </div>
  </div>
  <button class="bubble-toggle" id="bubbleToggle" onclick="toggleChat()">
    <span class="pulse-ring"></span>
    <span id="bubbleIcon">💬</span>
  </button>
</div>

<script>
// === SAUL MIRROR AI ===
const CHAT_RESPONSES = {
  'projects': 'We have 10 projects mirrored here:\n• Jeannie Nails (jeannienails.vercel.app)\n• ATV/Container Homes\n• Quantum Bots Agency\n• Fall of the Cabal\n• FlyToAustralia\n• The Deal Wizard\n• Drug Doctors\n• All About MD\n• Quanivo AI Agency\n• Backup Portal\n\nAll are accessible from this mirror!',
  'rules': 'All 13 Permanent Rules are enforced:\n1. 6-Hour Audit Cycle\n2. Code Protection\n3. Auto-Scaling\n4. QA Daemon 24/7\n5. New Project Onboarding\n6. No Deletions Ever\n7. Zero-Delay Heartbeat\n8. CEO Authority\n9. Zero Paid Services\n10. Backup Portal\n11. Master Credentials\n12. Rule Redundancy\n13. Independent Mirror\n\nView full: /RULES.md',
  'tests': 'Pre-migration tests to run:\n1. ✅ File integrity (1,699 files, 58MB)\n2. ✅ All sites HTTP 200\n3. ✅ Daemons heartbeat\n4. ✅ Backup portal login\n5. ✅ Manage login\n6. ✅ Rules readable\n7. ✅ Deploy test\n\nStatus: ALL PASSED ✅',
  'portal': 'Backup Portal is at: /backup-portal/\nNo password needed for testing.\nLogin: indie_empire / Recovery@2026!\nIt works with zero servers or backend.',
  'hello': 'Hey 👋 I\'m Saul, your mirror AI assistant. Ask me about projects, rules, testing, or the backup portal. I\'m here to help with the migration!',
  'help': 'I can tell you about:\n• Projects — mirrored site list\n• Rules — all 13 permanent rules\n• Tests — migration test results\n• Portal — backup portal info\n• Status — current mirror health\nJust type a question!',
  'status': '🟢 MIRROR STATUS: ONLINE\n• 10 projects mirrored\n• 1,699 files, 58MB\n• 4 daemons preserved\n• Security: clean ✅\n• HTTP: all 200 ✅\n• Migration: APPROVED ✅'
};

function toggleChat(){
  const win=document.getElementById('chatWindow');
  const tog=document.getElementById('bubbleToggle');
  const icon=document.getElementById('bubbleIcon');
  win.classList.toggle('open');
  tog.classList.toggle('open');
  icon.textContent=win.classList.contains('open')?'✕':'💬';
  
  // Send welcome if first open
  if(win.classList.contains('open') && document.getElementById('chatMessages').children.length===0){
    addBotMsg('Hey 👋 I\'m Saul, your mirror AI assistant. Ask me about projects, rules, testing, or the backup portal. I\'m here to help with the migration!');
  }
}

function addBotMsg(text){
  const msgs=document.getElementById('chatMessages');
  const d=document.createElement('div');
  d.className='chat-msg bot';
  d.innerHTML=text.replace(/\n/g,'<br>')+'<span class="time">Saul · just now</span>';
  msgs.appendChild(d);
  msgs.scrollTop=msgs.scrollHeight;
}

function addUserMsg(text){
  const msgs=document.getElementById('chatMessages');
  const d=document.createElement('div');
  d.className='chat-msg user';
  d.innerHTML=text+'<span class="time">You · just now</span>';
  msgs.appendChild(d);
  msgs.scrollTop=msgs.scrollHeight;
}

function sendMessage(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();
  if(!text) return;
  addUserMsg(text);
  input.value='';
  
  setTimeout(()=>{
    const key=text.toLowerCase().replace(/[^a-z0-9\s]/g,'').trim();
    let response=null;
    for(const [k,v] of Object.entries(CHAT_RESPONSES)){
      if(key.includes(k)){ response=v; break; }
    }
    addBotMsg(response||'I\'m not sure about that — try asking about projects, rules, tests, portal, or status!');
  },400);
}

function sendQuick(text){
  addUserMsg(text);
  document.getElementById('chatInput').value='';
  setTimeout(()=>{
    const key=text.toLowerCase();
    for(const [k,v] of Object.entries(CHAT_RESPONSES)){
      if(key.includes(k)){ addBotMsg(v); break; }
    }
  },300);
}
</script>
</body>
</html>
